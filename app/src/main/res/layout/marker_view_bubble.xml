<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    xmlns:tools="http://schemas.android.com/tools"
    app:cardBackgroundColor="@color/mappls_demo_background_colorSecondary"
    app:cardCornerRadius="10dp"
    app:cardElevation="5dp"
    app:cardUseCompatPadding="true"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:layout_margin="8dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:id="@+id/marker_window_title"
            android:layout_width="wrap_content"
            android:padding="8dp"
            android:text="This is info window"
            android:textStyle="bold"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/marker_window_button"
            android:layout_width="wrap_content"
            android:padding="8dp"
            android:textColor="@color/mappls_demo_colorPrimary"
            android:text="Button 1"
            android:layout_marginTop="4dp"
            android:background="@drawable/button_transparent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/marker_window_title"
            app:layout_constraintLeft_toLeftOf="parent"/>
        <TextView
            android:id="@+id/marker_window_button1"
            android:layout_width="wrap_content"
            android:padding="8dp"
            android:text="Button 2"
            android:layout_marginTop="4dp"
            android:layout_marginLeft="8dp"
            android:layout_marginStart="8dp"
            android:textColor="@color/mappls_demo_colorPrimary"
            android:background="@drawable/button_transparent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/marker_window_title"
            app:layout_constraintLeft_toRightOf="@id/marker_window_button" />
        <TextView
            android:id="@+id/marker_window_button2"
            android:layout_width="wrap_content"
            android:padding="8dp"
            android:text="Button 3"
            android:layout_marginTop="4dp"
            android:layout_marginLeft="8dp"
            android:layout_marginStart="8dp"
            android:textColor="@color/mappls_demo_colorPrimary"
            android:background="@drawable/button_transparent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/marker_window_title"
            app:layout_constraintLeft_toRightOf="@id/marker_window_button1" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>