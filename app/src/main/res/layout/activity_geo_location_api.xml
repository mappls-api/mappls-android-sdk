<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.restapis.GeoLocationApiActivity">

    <include
        android:id="@+id/geo_location_header"
        layout="@layout/mappls_app_header" />

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/geo_location_header"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <include layout="@layout/progressbar_layout"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/progressBar_layout"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>