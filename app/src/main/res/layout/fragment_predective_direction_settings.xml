<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1F232F"
    tools:context=".settings.fragment.PredectiveDirectionSettingsFragment">

    <include
        android:id="@+id/predective_direction_settings_header"
        layout="@layout/mappls_app_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/predective_direction_settings_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/origin_direction_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/background_with_no_corner"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_direction_origin_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Origin Location"
                    android:textColor="#FFFFFF"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/et_direction_origin_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/background_with_no_corner"
                    android:hint="Longitude,Latitude/Mappls Pin"
                    android:padding="8dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#C6D0F7"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_direction_origin_location" />


                <TextView
                    android:id="@+id/btn_direction_origin_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Save Origin Location"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_direction_origin_location" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/destination_direction_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/background_with_no_corner"
                app:layout_constraintTop_toBottomOf="@id/origin_direction_location_layout">

                <TextView
                    android:id="@+id/tv_direction_destination_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Destination Location"
                    android:textColor="#FFFFFF"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/et_direction_destination_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/background_with_no_corner"
                    android:hint="Longitude,Latitude/Mappls Pin"
                    android:padding="8dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#C6D0F7"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_direction_destination_location" />


                <TextView
                    android:id="@+id/btn_direction_destination_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Save Destination Location"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_direction_destination_location" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/waypoint_direction_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/background_with_no_corner"
                app:layout_constraintTop_toBottomOf="@id/destination_direction_location_layout">

                <TextView
                    android:id="@+id/tv_direction_waypoint_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Waypoint Location"
                    android:textColor="#FFFFFF"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/et_direction_waypoint_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/background_with_no_corner"
                    android:hint="(Viapoint-1);(Viapoint-2)"
                    android:padding="8dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#C6D0F7"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_direction_waypoint_location" />


                <TextView
                    android:id="@+id/btn_direction_waypoint_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Save Waypoint Location"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_direction_waypoint_location" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/direction_overview_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/waypoint_direction_location_layout"
                >
                <TextView
                    android:id="@+id/tv_direction_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Overview"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="#FFFFFF"/>

                <RadioGroup
                    android:id="@+id/rg_overview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:foregroundTint="@color/mappls_demo_colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tv_direction_overview">

                    <RadioButton
                        android:id="@+id/rb_overview_full"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full"
                        android:textColor="#FFFFFF"/>

                    <RadioButton
                        android:id="@+id/rb_overview_simplified"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Simplified"
                        android:textColor="#FFFFFF"/>

                    <RadioButton
                        android:id="@+id/rb_overview_false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="False"
                        android:textColor="#FFFFFF"/>

                </RadioGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_direction_alternative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Alternative Enable"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toBottomOf="@id/direction_overview_layout"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/direction_geometry_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/sw_direction_alternative"
                >
                <TextView
                    android:id="@+id/tv_direction_geometry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Geometry"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="#FFFFFF"/>

                <RadioGroup
                    android:id="@+id/rg_geometry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:foregroundTint="@color/mappls_demo_colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tv_direction_geometry">

                    <RadioButton
                        android:id="@+id/rb_geometry_polyline_five"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Polyline 5"
                        android:textColor="#FFFFFF"/>

                    <RadioButton
                        android:id="@+id/rb_geometry_polyline_six"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Polyline 6"
                        android:textColor="#FFFFFF"/>

                    <RadioButton
                        android:id="@+id/rb_geometry_coordiates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Geojson"
                        android:textColor="#FFFFFF"/>

                </RadioGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_direction_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Steps Enable"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toBottomOf="@id/direction_geometry_layout"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_predictive_direction_date_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/sw_direction_steps"
                >
                <TextView
                    android:id="@+id/tv_direction_date_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date Time"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="#FFFFFF"/>

                <RadioGroup
                    android:id="@+id/rg_date_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:foregroundTint="@color/mappls_demo_colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tv_direction_date_time">

                    <RadioButton
                        android:id="@+id/rb_date_time_current"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Time Current"
                        android:textColor="#FFFFFF"/>

                    <RadioButton
                        android:id="@+id/rb_date_time_specified"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Time Specified"
                        android:textColor="#FFFFFF"/>

                </RadioGroup>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_specified_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/rg_date_time">
                    <TextView
                        android:id="@+id/tv_direction_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Time For"
                        android:layout_margin="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        android:textColor="#FFFFFF"/>

                    <RadioGroup
                        android:id="@+id/rg_time_for"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="12dp"
                        android:foregroundTint="@color/mappls_demo_colorPrimary"
                        app:layout_constraintTop_toBottomOf="@id/tv_direction_type">

                        <RadioButton
                            android:id="@+id/rb_time_for_arrival"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Arrival"
                            android:textColor="#FFFFFF"/>

                        <RadioButton
                            android:id="@+id/rb_date_time_departure"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Departure"
                            android:textColor="#FFFFFF"/>

                    </RadioGroup>

                    <TextView
                        android:id="@+id/tv_predictive_time"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select Time"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_margin="12dp"
                        android:textSize="16sp"
                        app:layout_constraintTop_toBottomOf="@id/rg_time_for"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        android:textColor="#FFFFFF"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>