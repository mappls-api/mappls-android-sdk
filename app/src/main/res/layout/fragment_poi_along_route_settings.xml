<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#1F232F"
    tools:context=".settings.fragment.PoiAlongRouteSettingsFragment">

    <include
        android:id="@+id/poi_along_route_settings_header"
        layout="@layout/mappls_app_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/poi_along_route_settings_header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/origin_poi_along_route_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/background_with_no_corner"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tv_poi_along_route_origin_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Origin Location"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/et_poi_along_route_origin_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/background_with_no_corner"
                    android:hint="Longitude,Latitude/Mappls Pin"
                    android:padding="8dp"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:textColorHint="#C6D0F7"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_origin_location" />


                <TextView
                    android:id="@+id/btn_poi_along_route_origin_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Save Origin Location"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_poi_along_route_origin_location" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/destination_poi_along_route_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/background_with_no_corner"
                app:layout_constraintTop_toBottomOf="@id/origin_poi_along_route_location_layout">

                <TextView
                    android:id="@+id/tv_poi_along_route_destination_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Destination Location"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/et_poi_along_route_destination_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/background_with_no_corner"
                    android:hint="Longitude,Latitude/Mappls Pin"
                    android:padding="8dp"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:textColorHint="#C6D0F7"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_destination_location" />


                <TextView
                    android:id="@+id/btn_poi_along_route_destination_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Save Destination Location"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_poi_along_route_destination_location" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/poi_along_route_keyword_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/destination_poi_along_route_location_layout"
                >
                <TextView
                    android:id="@+id/tv_poi_along_route_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_poi_along_route_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tea/Coffee..."
                    android:padding="8dp"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_category"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_poi_along_route_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_poi_along_route_category"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Category"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/poi_along_route_buffer_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/poi_along_route_keyword_layout"
                >
                <TextView
                    android:id="@+id/tv_poi_along_route_buffer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Buffer"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_poi_along_route_buffer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="25"
                    android:padding="8dp"
                    android:inputType="number"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_buffer"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_poi_along_route_buffer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_poi_along_route_buffer"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Buffer"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/poi_along_route_page_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/poi_along_route_buffer_layout"
                >
                <TextView
                    android:id="@+id/tv_poi_along_route_page"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Page"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_poi_along_route_page"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="25"
                    android:padding="8dp"
                    android:inputType="number"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_page"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />

                <TextView
                    android:id="@+id/btn_poi_along_route_page"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_poi_along_route_page"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Page"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_poi_along_route_sort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Sort"
                android:visibility="gone"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toBottomOf="@id/poi_along_route_page_layout"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/poi_along_route_filter_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/sw_poi_along_route_sort"
                >
                <TextView
                    android:id="@+id/tv_poi_along_route_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Filter"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_poi_along_route_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="plugType:TP2"
                    android:padding="8dp"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_filter"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />

                <TextView
                    android:id="@+id/btn_poi_along_route_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_poi_along_route_filter"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Filter"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/poi_along_route_geometry_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/poi_along_route_filter_layout"
                >
                <TextView
                    android:id="@+id/tv_poi_along_route_geometry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Geometry"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <RadioGroup
                    android:id="@+id/rg_geometry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:foregroundTint="@color/mappls_demo_colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tv_poi_along_route_geometry">

                    <RadioButton
                        android:id="@+id/rb_geometry_polyline_five"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Polyline 5"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_geometry_polyline_six"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Polyline 6"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                </RadioGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>