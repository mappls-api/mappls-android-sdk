<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.restapis.NearbyReportActivity">

    <include
        android:id="@+id/nearby_report_header"
        layout="@layout/mappls_app_header" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nearby_report_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/search_text_bg"
        app:layout_constraintTop_toBottomOf="@id/nearby_report_header"
        >

        <TextView
            android:id="@+id/btn_nearby_report_search"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            android:text="Search Nearby"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:layout_margin="12dp"
            android:background="@drawable/solid_btn_bg"
            android:padding="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/nearby_report_layout"
        app:layout_constraintBottom_toTopOf="@id/nearby_report_show_hide_response_layout"
        />

    <include layout="@layout/progressbar_layout"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/progressBar_layout"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <FrameLayout
        android:id="@+id/selection_box"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/nearby_report_layout"
        app:layout_constraintBottom_toTopOf="@id/nearby_report_show_hide_response_layout"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:alpha="0.5"
        android:background="#A4A4E5"/>

    <ScrollView
        android:id="@+id/nearby_report_json_response_sv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:padding="8dp"
        android:visibility="gone"
        android:background="@drawable/search_result_list_bg"
        app:layout_constraintTop_toBottomOf="@id/nearby_report_layout"
        app:layout_constraintBottom_toTopOf="@id/nearby_report_show_hide_response_layout">
        <TextView
            android:id="@+id/nearby_report_json_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:textSize="14sp"
            />
    </ScrollView>

    <include
        android:id="@+id/nearby_report_show_hide_response_layout"
        layout="@layout/show_hide_response_layout"/>

</androidx.constraintlayout.widget.ConstraintLayout>