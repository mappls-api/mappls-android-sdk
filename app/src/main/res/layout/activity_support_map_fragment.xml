<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.events.SupportMapFragmentActivity">

    <include
        android:id="@+id/support_map_fragment_header"
        layout="@layout/mappls_app_header" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/support_map_fragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:name="com.mappls.sdk.maps.SupportMapFragment"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/support_map_fragment_header"/>

</androidx.constraintlayout.widget.ConstraintLayout>