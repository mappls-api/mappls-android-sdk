<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/sub_category_bg"
    android:layout_margin="8dp"
    android:paddingBottom="16dp">

    <ImageView
        android:id="@+id/iv_sub_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <TextView
        android:id="@+id/tv_sub_category_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/mappls_demo_text_colorPrimary"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/iv_sub_category"
        />
    <TextView
        android:id="@+id/tv_sub_category_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/mappls_demo_text_colorSecondary"
        android:textSize="14sp"
        android:layout_marginLeft="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_sub_category_name"
        />


</androidx.constraintlayout.widget.ConstraintLayout>