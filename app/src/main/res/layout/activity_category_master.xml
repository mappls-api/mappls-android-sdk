<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1F232F"
    tools:context=".activity.restapis.CategoryMasterActivity">


    <include
        android:id="@+id/category_master_settings_header"
        layout="@layout/mappls_app_header" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_category_master"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/category_master_settings_header"
        app:layout_constraintBottom_toTopOf="@id/category_master_show_hide_response_layout"/>



    <ScrollView
        android:id="@+id/category_master_json_response_sv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:padding="8dp"
        android:visibility="gone"
        android:background="@drawable/search_result_list_bg"
        app:layout_constraintTop_toBottomOf="@id/category_master_settings_header"
        app:layout_constraintBottom_toTopOf="@id/category_master_show_hide_response_layout">
        <TextView
            android:id="@+id/category_master_json_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:textSize="14sp"
            />
    </ScrollView>


    <include
        android:id="@+id/category_master_show_hide_response_layout"
        layout="@layout/show_hide_response_layout"/>



</androidx.constraintlayout.widget.ConstraintLayout>