<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mappls_demo_background_colorSecondary"
    tools:context=".activity.widgets.GeoFenceActivity">

    <include
        android:id="@+id/geo_fence_header"
        layout="@layout/mappls_app_header" />

    <TextView
        android:id="@+id/tv_basic_geofence"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="12dp"
        android:text="Basic Geofence"
        android:padding="12dp"
        android:textColor="@color/mappls_demo_colorPrimary"
        android:background="@drawable/button_transparent"
        app:layout_constraintBottom_toTopOf="@id/tv_custom_geofence"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/geo_fence_header"/>
    <TextView
        android:id="@+id/tv_custom_geofence"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:text="Custom Geofence"
        android:textColor="@color/mappls_demo_colorPrimary"
        android:background="@drawable/button_transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_basic_geofence"/>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"

        />
</androidx.constraintlayout.widget.ConstraintLayout>