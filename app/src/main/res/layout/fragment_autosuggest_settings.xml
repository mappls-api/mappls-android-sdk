<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/mappls_demo_background_colorSecondary"
    android:clickable="true"
    android:focusable="true"
    tools:context=".settings.fragment.AutosuggestSettingsFragment">


    <include
        android:id="@+id/autosuggest_settings_header"
        layout="@layout/mappls_app_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/autosuggest_settings_header"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_current_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Set Current Location"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toTopOf="parent"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/custom_location_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/sw_current_location"
                >
                <TextView
                    android:id="@+id/tv_custom_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Custom Location"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_custom_lat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Latitude"
                    android:padding="8dp"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:inputType="numberDecimal"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_custom_location"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toLeftOf="@id/et_custom_lng"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />

                <EditText
                    android:id="@+id/et_custom_lng"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="Longitude"
                    android:padding="8dp"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:inputType="numberDecimal"
                    android:textColorHint="#C6D0F7"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_custom_location"
                    app:layout_constraintLeft_toRightOf="@id/et_custom_lat"
                    app:layout_constraintRight_toRightOf="parent"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_custom_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_custom_lat"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Custom Location"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/pod_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/custom_location_layout"
                >
                <TextView
                    android:id="@+id/tv_pod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pod"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <RadioGroup
                    android:id="@+id/rg_pod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:foregroundTint="@color/mappls_demo_colorPrimary"
                    app:layout_constraintTop_toBottomOf="@id/tv_pod">

                    <RadioButton
                        android:id="@+id/rb_sub_sub_locality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sub Sub Locality"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_sub_locality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sub Locality"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_locality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Locality"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_city"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="City"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_village"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Village"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_sub_district"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sub District"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_district"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="District"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="State"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>

                    <RadioButton
                        android:id="@+id/rb_poi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="POI"
                        android:textColor="@color/mappls_demo_text_colorPrimary"/>


                </RadioGroup>


                <TextView
                    android:id="@+id/btn_clear_pod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/rg_pod"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Clear All Pods"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/filter_layout"
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/pod_layout"
                >
                <TextView
                    android:id="@+id/tv_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Filter"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_filter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:hint="Enter Text"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_filter"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_filter"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Filter"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_tokenise_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                android:text="Tokenize Address"
                app:layout_constraintTop_toBottomOf="@id/filter_layout"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_bridge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Bridge"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toBottomOf="@id/sw_tokenise_address"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_hyperlocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Hyperlocal"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toBottomOf="@id/sw_bridge"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_explain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:text="Explain"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                app:layout_constraintTop_toBottomOf="@id/sw_hyperlocal"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/response_lang_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/sw_explain"
                >
                <TextView
                    android:id="@+id/tv_response_lang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Response Lang"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_response_lang"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:hint="Enter Text"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_response_lang"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_response_lang"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_response_lang"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Filter"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_enable_map_center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:thumbTint="#FFFFFF"
                app:trackTint="@color/mappls_demo_colorPrimary"
                app:switchMinWidth="30dp"
                android:text="Enable Map Center in Request"
                app:layout_constraintTop_toBottomOf="@id/response_lang_layout"
                android:textColor="@color/mappls_demo_text_colorPrimary"
                android:textSize="14sp"
                />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/custom_primary_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintTop_toBottomOf="@id/sw_enable_map_center"
                >
                <TextView
                    android:id="@+id/tv_is_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Is Primary"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_primary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:hint="Enter Text"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_is_primary"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_is_primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_primary"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Is Primary"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/zoom_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_with_no_corner"
                android:layout_margin="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/custom_primary_layout"
                >
                <TextView
                    android:id="@+id/tv_zoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Zoom"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColor="@color/mappls_demo_text_colorPrimary"/>

                <EditText
                    android:id="@+id/et_zoom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:hint="Enter Value(Double)"
                    android:inputType="numberDecimal"
                    android:background="@drawable/background_with_no_corner"
                    app:layout_constraintTop_toBottomOf="@id/tv_zoom"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    android:textColorHint="#C6D0F7"
                    android:layout_margin="12dp"
                    />


                <TextView
                    android:id="@+id/btn_zoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/et_zoom"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:padding="8dp"
                    android:text="Save Zoom"
                    android:textColor="@color/mappls_demo_text_colorPrimary"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:background="@drawable/tranparent_btn_bg"
                    android:layout_margin="12dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>