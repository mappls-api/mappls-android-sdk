<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginLeft="8dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginRight="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/rv_search_item_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:src="@drawable/search_result_icon"/>

    <TextView
        android:id="@+id/tv_place_name"
        android:layout_width="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_height="wrap_content"
        android:text="hello"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/rv_search_item_icon"
        app:layout_constraintRight_toLeftOf="@+id/tv_distance"
        app:layout_constraintRight_toRightOf="parent"
        android:textSize="16sp"
        android:textColor="@color/mappls_demo_text_colorPrimary"
        />
    <TextView
        android:id="@+id/tv_distance"
        android:layout_width="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_height="wrap_content"
        android:text="hello"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:textSize="14sp"
        android:textColor="@color/mappls_demo_text_colorPrimary"
        />
    <TextView
        android:id="@+id/tv_place_address"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:maxLines="2"
        android:text="hello"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/tv_place_name"
        app:layout_constraintLeft_toRightOf="@id/rv_search_item_icon"
        app:layout_constraintRight_toRightOf="parent"
        android:textSize="14sp"
        android:textColor="#C6D0F7"
        />

</androidx.constraintlayout.widget.ConstraintLayout>