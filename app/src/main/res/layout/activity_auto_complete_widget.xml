<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mappls_demo_background_colorSecondary"
    tools:context=".activity.widgets.AutoCompleteWidgetActivity">

    <include
        android:id="@+id/place_auto_complete_header"
        layout="@layout/mappls_app_header" />
    <TextView
        android:id="@+id/tv_card_fragment"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:layout_margin="12dp"
        android:text="Fragment With Card Mode"
        android:padding="12dp"
        android:textColor="@color/mappls_demo_colorPrimary"
        android:background="@drawable/button_transparent"
        app:layout_constraintBottom_toTopOf="@id/tv_full_fragment"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/place_auto_complete_header"/>
    <TextView
        android:id="@+id/tv_full_fragment"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:text="Fragment With Full Mode"
        android:textColor="@color/mappls_demo_colorPrimary"
        android:background="@drawable/button_transparent"
        app:layout_constraintBottom_toTopOf="@id/tv_card_activity"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_card_fragment"/>

    <TextView
        android:id="@+id/tv_card_activity"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:text="Activity With Card Mode"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:textColor="@color/mappls_demo_colorPrimary"
        android:background="@drawable/button_transparent"
        app:layout_constraintBottom_toTopOf="@id/tv_full_activity"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_full_fragment"/>
    <TextView
        android:id="@+id/tv_full_activity"
        android:layout_height="wrap_content"
        android:layout_width="wrap_content"
        android:text="Activity With Full Mode"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:textColor="@color/mappls_demo_colorPrimary"
        android:background="@drawable/button_transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_card_activity"/>
    <FrameLayout
        android:id="@+id/place_autocomplete_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"

        />
</androidx.constraintlayout.widget.ConstraintLayout>