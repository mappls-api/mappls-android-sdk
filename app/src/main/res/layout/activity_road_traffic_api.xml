<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.restapis.RoadTrafficApiActivity">

    <include
        android:id="@+id/road_traffic_header"
        layout="@layout/mappls_app_header" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/search_latlng_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/search_text_bg"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/road_traffic_header">

        <EditText
            android:id="@+id/search_et"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Lat,Lng"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:textColorHint="#C6D0F7"
            android:textSize="14sp"
            android:background="@drawable/background_with_no_corner"
            android:drawableStart="@drawable/search_icon_drawable"
            android:drawablePadding="8dp"
            android:paddingHorizontal="16dp"
            android:layout_margin="5dp"
            android:paddingVertical="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_geocode_search" />

        <EditText
            android:id="@+id/radius_et"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Radius"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:layout_margin="5dp"
            android:textColorHint="#C6D0F7"
            android:textSize="14sp"
            android:background="@drawable/background_with_no_corner"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/search_et"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btn_geocode_search" />

        <TextView
            android:id="@+id/btn_geocode_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call Api"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:background="@drawable/solid_btn_bg"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            app:layout_constraintTop_toTopOf="@id/search_et"
            app:layout_constraintBottom_toBottomOf="@id/radius_et"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>



    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/search_latlng_layout"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <include layout="@layout/progressbar_layout"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/traffic_progressbar"

        app:layout_constraintBottom_toBottomOf="parent"/>
    <ScrollView
        android:id="@+id/road_traffic_json_response_sv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:padding="8dp"
        android:visibility="gone"
        android:background="@drawable/search_result_list_bg"
        app:layout_constraintTop_toBottomOf="@id/search_latlng_layout"
        app:layout_constraintBottom_toTopOf="@id/road_traffic_show_hide_response_layout">
        <TextView
            android:id="@+id/fuelCost_json_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:textSize="14sp"
            />
    </ScrollView>

    <include
        android:id="@+id/road_traffic_show_hide_response_layout"
        layout="@layout/show_hide_response_layout"/>

    <FrameLayout
        android:id="@+id/fuelCost_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"

        />
</androidx.constraintlayout.widget.ConstraintLayout>