<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.restapis.RouteReportSummaryActivity">

    <include
        android:id="@+id/route_summary_header"
        layout="@layout/mappls_app_header" />

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/route_summary_header"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <include layout="@layout/progressbar_layout"
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/progressBar_layout"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <ScrollView
        android:id="@+id/route_summary_json_response_sv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:padding="8dp"
        android:visibility="gone"
        android:background="@drawable/search_result_list_bg"
        app:layout_constraintTop_toBottomOf="@id/route_summary_header"
        app:layout_constraintBottom_toTopOf="@id/route_summary_show_hide_response_layout">
        <TextView
            android:id="@+id/route_summary_json_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:textSize="14sp"
            />
    </ScrollView>

    <include
        android:id="@+id/route_summary_show_hide_response_layout"
        layout="@layout/show_hide_response_layout"/>


    <FrameLayout
        android:id="@+id/route_summary_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"

        />

</androidx.constraintlayout.widget.ConstraintLayout>