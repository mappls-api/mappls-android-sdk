<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragment.TypeSelectionFragment">

    <include
        android:id="@+id/type_selection_header"
        layout="@layout/map_header" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/category_type_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/type_selection_header"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@color/mappls_demo_background_colorPrimary"
        />

</androidx.constraintlayout.widget.ConstraintLayout>