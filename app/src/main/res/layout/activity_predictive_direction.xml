    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/predective_direction_option_layout"
        app:layout_constraintBottom_toBottomOf="parent"/>


    <ScrollView
        android:id="@+id/directions_json_response_sv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginRight="8dp"
        android:layout_marginBottom="4dp"
        android:padding="8dp"
        android:visibility="gone"
        android:background="@drawable/search_result_list_bg"
        app:layout_constraintTop_toBottomOf="@id/predective_direction_option_layout"
        app:layout_constraintBottom_toTopOf="@id/predective_direction_show_hide_response_layout">
        <TextView
            android:id="@+id/directions_json_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:textSize="14sp"
            />
    </ScrollView>

    <ImageView
        android:id="@+id/iv_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/fab_icon_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:src="@drawable/searching_gps_icon"
        android:padding="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="142dp"/>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/directions_detail_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rev_geocode_result_bg"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingBottom="68dp">

        <TextView
            android:id="@+id/tv_directions_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="12dp"
            android:textSize="16sp"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            />

        <TextView
            android:id="@+id/tv_directions_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tv_directions_distance"
            android:layout_margin="12dp"
            android:textSize="16sp"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>


    <include
        android:id="@+id/predective_direction_show_hide_response_layout"
        layout="@layout/show_hide_response_layout"/>


    <FrameLayout
        android:id="@+id/directions_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"

        />

</androidx.constraintlayout.widget.ConstraintLayout>