<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/transparency_rounded_bg"
    android:layout_margin="4dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_style_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/mappls_demo_text_colorPrimary"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_style_description"
        app:layout_constraintRight_toLeftOf="@id/iv_style_icon"/>




    <TextView
        android:id="@+id/tv_style_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/mappls_demo_text_colorSecondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_style_name"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/iv_style_icon"/>


    <ImageView
        android:id="@+id/iv_style_icon"
        android:layout_width="98dp"
        android:layout_height="80dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />






</androidx.constraintlayout.widget.ConstraintLayout>