<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.widgets.autocomplete.CardModeFragmentActivity">

    <include
        android:id="@+id/card_fragment_header"
        layout="@layout/mappls_app_header" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/search_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/search_text_bg"
        app:layout_constraintTop_toBottomOf="@id/card_fragment_header"
        >

        <TextView
            android:id="@+id/tv_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="12dp"
            android:paddingLeft="10dp"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingRight="10dp"
            android:textColor="@color/mappls_demo_text_colorPrimary"
            android:text="Search"
            android:gravity="center_vertical"
            app:drawableLeftCompat="@drawable/search_icon_drawable"
            app:drawableStartCompat="@drawable/search_icon_drawable"
            android:paddingEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@drawable/background_with_no_corner"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.mappls.sdk.maps.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_layout"/>


    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/autocomplete_fragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        />


</androidx.constraintlayout.widget.ConstraintLayout>